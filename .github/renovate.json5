{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "pip_requirements": {
    // Default pip_requirements fileMatch only allows [\w-]* between
    // "requirements" and ".txt", so per-instrumentation
    // requirements.latest.txt files are skipped without this.
    // requirements.oldest.txt is intentionally not matched: those pins
    // exist to test against the oldest supported versions.
    "managerFilePatterns": ["/(^|/)requirements\\.latest\\.txt$/"]
  },
  "packageRules": [
    {
      "groupName": "all patch versions",
      "matchUpdateTypes": ["patch"],
      "schedule": ["before 8am every weekday"]
    },
    {
      "matchUpdateTypes": ["minor", "major"],
      "schedule": ["before 8am on Monday"]
    },
    {
      // group all GitHub Actions updates into a single weekly PR
      // (Renovate applies packageRules in order and later rules win)
      "groupName": "github actions",
      "matchManagers": [
        "github-actions"
      ],
      "schedule": [
        "before 8am on Tuesday"
      ]
    }
  ],
  "labels": [
    "dependencies"
  ]
}
